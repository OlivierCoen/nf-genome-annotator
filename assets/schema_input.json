{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/genome_annotator/master/assets/schema_input.json",
    "title": "genome_annotator pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and cannot contain spaces",
                "meta": ["id"]
            },
            "genome": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^([\\S\\s]*\\/)?[^\\s\\/]+\\.f(ast|n)?a(\\.gz)?$",
                "errorMessage": "Genome fasta file must be provided, cannot contain spaces and must have extension '.fa', 'fna' or '.fasta' (possibly gzip compressed)"
            },
            "gff": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^([\\S\\s]*\\/)?[^\\s\\/]+\\.(gtf|gff|gff3)$",
                "errorMessage": "Existing annotation GTF file cannot contain spaces and must have extension '.gtf', '.gff' or '.gff3'"
            },
            "rnaseq_bam": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "file-path",
                  "exists": true,
                  "pattern": "^([\\S\\s]*\\/)?[^\\s\\/]+\\.bam$",
                  "errorMessage": "BAM file cannot contain spaces and must have extension '.bam'"
                }
            },
            "rnaseq_fastq": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "fastq_1": {
                        "type": "string",
                        "pattern": "^\\S+\\.f(ast)?q\\.gz$",
                        "format": "file-path",
                        "errorMessage": "FastQ file for reads 1 must be provided, cannot contain spaces and must have extension '.fq.gz' or '.fastq.gz'"
                    },
                    "fastq_2": {
                        "errorMessage": "FastQ file for reads 2 cannot contain spaces and must have extension '.fq.gz' or '.fastq.gz'",
                        "anyOf": [
                            {
                                "type": "string",
                                "pattern": "^\\S+\\.f(ast)?q\\.gz$",
                                "format": "file-path"
                            },
                            {
                                "type": "string",
                                "maxLength": 0
                            }
                        ]
                    }
                  }
                }
            },
            "rnaseq_public_id": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^(SR|ER)[A-Z0-9]+$",
                "errorMessage": "READ IDs must start with 'SR' or 'ER'. Hor now, only SRA and ENA IDs are supported. If you encounter issues or if your reads come from other databases, please consider using nf-core/fetchngs first."
              }
            },
            "proteins": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^([\\S\\s]*\\/)?[^\\s\\/]+\\.f(ast|a)?a(\\.gz)?$",
                "errorMessage": "Protein Fasta file cannot contain spaces and must have extension '.fa', 'faa' or '.fasta' (possibly gzip compressed)"
              }
            },
            "braker_gtf": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^([\\S\\s]*\\/)?[^\\s\\/]+\\.gtf$",
                "errorMessage": "Braker GTF file cannot contain spaces and must have extension '.gtf'"
            },
            "hintsfile": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^([\\S\\s]*\\/)?[^\\s\\/]+\\.hintsfile.gff$",
                "errorMessage": "Braker hints GFF file cannot contain spaces and must have extension '.hintsfile.gff'"
            }
        },
        "required": ["sample", "genome"]
    }
}
